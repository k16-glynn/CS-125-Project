#include <stdio.h>
#include <string.h>


void hangmanFile(int wrongGuesses)
{
  FILE*hangman = fopen("hangman.txt","r");

  int i;
  char line[100];

  switch(wrongGuesses)
  {
  case(0):
    for(i = 1; i<9; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
  
  case(1):
    for(i = 10; i<18; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
    
  case(2):
    for(i = 19; i<27; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
    
  case(3):
    for(i = 27; i<35; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
    
  case(4):
    for(i = 36; i<44; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
    
  case(5):
    for(i = 44; i<52; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
    
  case(6):
    for(i = 52; i<60; i++)
    {
      fgets(line,100,hangman);
      printf("%s",line);
    }
    break;
  }
  
  fclose(hangman);
}

int main()
{

 int wrongGuesses = 0;
 hangmanFile(wrongGuesses);
 
 return 0;
}
