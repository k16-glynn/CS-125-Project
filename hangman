#include <stdio.h>
#include <string.h>

char words[3][50] = {"h a b i t a t", "i c e c a p s", "r a b b i t s"};

char* wordArray()
{
  int number = rand()%3;
  printf("%s\n", words[number]);
  
return words[number];
}




char userInput()
{
  char letter;
  printf("letter: ");
  scanf(" %c", &letter);
  
  
  while (!isalpha(letter)){
    printf("Invalid, try again: \n ");
    scanf(" %c", &letter);
  }
  
  letter = tolower(letter);
return letter;
}




int main()
{
  srand(time(NULL));

  int dashLoop, checkLoop, death, deathLoop, letterFound, wrongGuesses=0;
  char word[50], dash[50], input; 
  
  
  
  strcpy(word, wordArray());
  printf("%s\n\n", word); 
  
  
  for(dashLoop=0; dashLoop < strlen(word); dashLoop+=2)
  {
    dash[dashLoop] = '_';
    dash[dashLoop+1] = ' ';
  }
  dash[dashLoop] = 0; // removes junk in memory 
  printf("%s\n", dash);
  
    
  
  
  input = userInput();
  
  while (strncmp(dash,word, strlen(word)) != 0)
  {
  
    letterFound = 0;
    
    for(checkLoop=0; checkLoop < strlen(word); checkLoop+=2)
    {
       if(word[checkLoop] == input)
       {
         dash[checkLoop] = input;
         printf("%s\n", dash);
         letterFound = 1;
       }
    }
    
    if (letterFound == 0)
    {
      wrongGuesses++;
  
      if (wrongGuesses >= 5)
      {
        printf("Too many wrong guesses!\n");
        return 0;   // exit the game
      }
    }
    
    if(strncmp(dash,word, strlen(word)) != 0)
    input = userInput();
  }
  
  printf("%s", dash);
  printf("\n");
  
return 0;
}



